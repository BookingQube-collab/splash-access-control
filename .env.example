# Supabase — copy from Dashboard → Project Settings → API
# Local dev: you can also set these in Admin → Settings (writes .env.local).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Passkeys off by default — no automatic GoTrue probe (avoids 404 in dev tools).
# Set to true after enabling Authentication → Passkeys in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_PASSKEYS_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Secret service_role key (server-only). Required for admin user create/update/delete.
# Do NOT prefix with NEXT_PUBLIC_ or VITE_ — that would expose it to the browser.
# After changing env files, restart the dev server: npm run dev
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# BookingQube (server-only — optional if stored in Admin → Settings → BookingQube)
BOOKINGQUBE_BASE_URL=https://bookingqube-staging-deb2ecbxcrd5cmbq.eastus-01.azurewebsites.net/api
BOOKINGQUBE_API_VERSION=v1
BOOKINGQUBE_API_KEY=

# Optional: "Download SummerSplash App" button in pass-ready modal (App Store / Play / marketing URL)
# NEXT_PUBLIC_APP_DOWNLOAD_URL=https://apps.apple.com/app/your-app-id

# Scandit barcode scanner (optional — preferred in Admin → Settings → Scanner)
# License key and enable toggle are stored in Supabase app_settings (scandit_api_key, scandit_enabled).
# Scanners fetch the key at runtime via getScanditConfig(); no env var is required when using Admin settings.

# Public site URL — pass links, hero image in emails, and QR payload (required in production).
# Without this, server falls back to http://localhost:3000 (broken in recipient inboxes).
# Vercel preview/production: set in Project → Settings → Environment Variables.
# NEXT_PUBLIC_SITE_URL=https://passes.summersplash.qa
# NEXT_PUBLIC_SITE_URL=https://splash-access-control.vercel.app

# Mailgun — transactional digital pass email (server-only; optional if stored in Admin → Settings)
# https://documentation.mailgun.com/docs/mailgun/api/send/send-messages
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=passes@mg.yourdomain.com
MAILGUN_ENABLED=false
# Display name in the From header (optional; defaults to "Summer Splash 2026")
# MAIL_FROM_NAME=Summer Splash 2026
# Optional: EU region — https://api.eu.mailgun.net
# MAILGUN_API_BASE_URL=https://api.eu.mailgun.net
# Optional email content overrides
# MAILGUN_SUPPORT_EMAIL=info@eeeqa.com
# MAILGUN_SUPPORT_PHONE=+974 5113 8418
# EVENT_VENUE_NAME=Beach Festival '26
# Optional footer / banner image URLs (absolute HTTPS); omit to use styled text or skip illustration
# EVENT_EMAIL_VISIT_QATAR_LOGO_URL=https://passes.summersplash.qa/brand/visit-qatar.png
# EVENT_EMAIL_HALA_SUMMER_LOGO_URL=https://passes.summersplash.qa/brand/hala-summer.png
# EVENT_EMAIL_GATE_ILLUSTRATION_URL=https://passes.summersplash.qa/brand/email-gate.png
# EVENT_SOCIAL_INSTAGRAM=https://instagram.com/summersplash
# EVENT_SOCIAL_FACEBOOK=https://facebook.com/summersplash
# EVENT_SOCIAL_X=https://x.com/summersplash
# EVENT_SOCIAL_YOUTUBE=https://youtube.com/@summersplash